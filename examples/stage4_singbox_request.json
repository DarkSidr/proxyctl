{
  "node": {
    "id": "node-1",
    "name": "eu-1",
    "host": "vpn.example.com"
  },
  "inbounds": [
    {
      "id": "in-vless",
      "type": "vless",
      "engine": "sing-box",
      "node_id": "node-1",
      "domain": "vpn.example.com",
      "port": 443,
      "tls_enabled": true,
      "transport": "ws",
      "path": "/ws",
      "enabled": true
    },
    {
      "id": "in-hy2",
      "type": "hysteria2",
      "engine": "sing-box",
      "node_id": "node-1",
      "domain": "vpn.example.com",
      "port": 8443,
      "tls_enabled": true,
      "transport": "udp",
      "sni": "hy2.example.com",
      "enabled": true
    }
  ],
  "credentials": [
    {
      "id": "cred-vless",
      "inbound_id": "in-vless",
      "kind": "uuid",
      "secret": "11111111-1111-1111-1111-111111111111"
    },
    {
      "id": "cred-hy2",
      "inbound_id": "in-hy2",
      "kind": "password",
      "secret": "hy2-secret"
    }
  ]
}

